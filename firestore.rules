// =============================================================================
// REGLES FIRESTORE PROPOSEES — CONSOLIDEES (jusqu'au correctif post-Sprint 11)
// =============================================================================
// Ce fichier est une PROPOSITION CONSOLIDEE. Il n'a pas ete deploye
// automatiquement sur le projet Firebase (conformement a la consigne "les
// regles Firestore restent la seule source de securite" + pratique deja
// etablie depuis le Sprint 3 : proposer, documenter, ne jamais appliquer
// automatiquement). A relire humainement avant toute publication,
// conformement a CHARTE_DEVELOPPEMENT_PHARMEVAL.md, section 14.2.
//
// ⚠️ CE FICHIER DOIT ETRE (RE)PUBLIE MANUELLEMENT s'il n'est pas deja a
// jour en production, en particulier pour les corrections/ajouts suivants :
//   - Sprint 8 puis resserree au correctif v1.9.1 : mise a jour
//     administrative de users/{userId} strictement limitee aux champs
//     role/status (voir RAPPORT_CORRECTIF_1.9.1.md).
//   - Correctif post-Sprint 10 : isRequesterAdmin() verifie desormais
//     AUSSI le statut actif - un administrateur suspendu perd
//     immediatement tous ses droits sur TOUTES les collections de ce
//     fichier, pas seulement une regle isolee.
//   - Sprint 11 : questions/{pedagogicalId} accepte desormais aussi une
//     transition de statut et une edition limitee (explanation/tags/
//     source). Nouvelle collection question_audit_logs/.
//   - CORRECTIF (avant validation du Sprint 11) : suppression securisee.
//     La suppression definitive (allow delete) n'est plus ouverte a tout
//     administrateur depuis n'importe quel statut - elle exige desormais
//     que la question soit DEJA a la corbeille (status == 'trash'),
//     dernier maillon du workflow Question -> Archivee -> Corbeille ->
//     Suppression definitive. Nouvelle regle de transition dediee et
//     strictement bornee pour archived <-> trash.
//
// Historique cumule de ce fichier (voir chaque rapport pour le detail) :
//   - Sprints 3 et 4 : users/{userId} et ses evaluations.
//   - Sprint 8 (+ correctif v1.9.1) : mise a jour administrative resserree
//     de users/{userId}, audit_logs/ (journal des actions administrateur).
//   - Sprint 10 (+ correctif post-Sprint 10) : questions/ (catalogue
//     global, identifiant = pedagogicalId), importLogs/ (journal des
//     imports), isRequesterAdmin() renforcee (role ET statut actif).
//   - Sprint 11 : questions/ etendue (transition de statut, edition
//     limitee) ; question_audit_logs/ (journal des actions de gestion de
//     la Banque de questions).
//   - Correctif (avant validation du Sprint 11) : suppression securisee
//     (Question -> Archivee -> Corbeille -> Suppression definitive),
//     regle de transition archived<->trash dediee, suppression contrainte
//     au statut "trash" uniquement.
// =============================================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // CORRECTIF (post-Sprint 10) : verifie desormais SIMULTANEMENT le role
    // ET le statut. Un administrateur SUSPENDU (statut "suspended", voir
    // Sprint 8) ne doit conserver AUCUN droit administratif, meme si son
    // champ `role` vaut toujours "admin" - la suspension d'un compte doit
    // etre immediatement effective cote regles de securite, pas seulement
    // cote interface (js/admin.js masque deja les actions pour un compte
    // suspendu, mais cette regle est la protection reelle, independante
    // de toute discipline du code client).
    function isRequesterAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'active';
    }

    // -------------------------------------------------------------------
    // NOTE IMPORTANTE (garantie "toujours au moins un administrateur actif",
    // reconfirmee au correctif v1.9.1) : Pharmeval empeche de retrograder ou
    // de suspendre le dernier administrateur actif restant.
    //
    // Cette garantie est actuellement implementee et testee au niveau
    // APPLICATIF UNIQUEMENT (js/services/admin-service.js, fonction
    // countActiveAdmins() dans user-management-service.js), PAS au niveau
    // de ces regles Firestore. Choix assume et deliberement NON change par
    // ce correctif : simuler un comptage global d'administrateurs actifs
    // directement dans une regle Firestore serait fragile (necessiterait
    // une fonction d'agregation count() appliquee a une requete filtree,
    // bien plus complexe et moins fiable ici qu'un simple get() sur un
    // document unique, deja utilise ci-dessus pour isRequesterAdmin()).
    //
    // Consequence honnete a documenter : un administrateur techniquement
    // capable de contourner entierement l'interface ET le service
    // applicatif (ex. appel Firestore direct depuis la console du
    // navigateur) pourrait aujourd'hui encore retrograder ou suspendre le
    // dernier administrateur actif, malgre le refus systematique de
    // l'application normale. Ce risque est juge acceptable pour l'instant
    // (l'application normale l'empeche efficacement) ; une protection
    // serveur plus robuste (Cloud Function declenchee sur ecriture, ou une
    // operation serveur transactionnelle dediee) devra etre mise en place
    // ulterieurement si ce risque devient une preoccupation reelle - voir
    // RAPPORT_CORRECTIF_1.9.1.md, "Limite connue".
    // -------------------------------------------------------------------

    match /users/{userId} {

      // --- Lecture (Sprint 3, inchangee + Sprint 8) ---
      // Un utilisateur lit son propre document, OU un administrateur lit
      // n'importe quel document (necessaire pour le tableau du Centre
      // d'administration).
      allow read: if request.auth != null &&
                    (request.auth.uid == userId || isRequesterAdmin());

      // --- Creation (Sprint 3, inchangee) ---
      // Uniquement son propre document, avec les valeurs par defaut
      // attendues (aucune auto-promotion possible des la creation du compte).
      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.uid == userId
                    && request.resource.data.role == 'user'
                    && request.resource.data.status == 'active'
                    && request.resource.data.profileCompleted == false;

      // --- Mise a jour par le PROPRIETAIRE lui-meme (Sprint 3, inchangee) ---
      // role/status/uid/createdAt restent strictement proteges : un
      // utilisateur ne peut jamais modifier ces champs sur son propre
      // document, meme s'il est administrateur (voir plus bas, regle
      // separee et plus restrictive pour l'auto-modification).
      allow update: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.uid == resource.data.uid
                    && request.resource.data.role == resource.data.role
                    && request.resource.data.status == resource.data.status
                    && request.resource.data.createdAt == resource.data.createdAt;

      // --- Mise a jour par un ADMINISTRATEUR, sur le document d'un AUTRE
      // utilisateur uniquement (CORRECTIF v1.9.1 - regle resserree) ---
      //
      // Un administrateur peut modifier UNIQUEMENT les champs `role` et/ou
      // `status` d'un autre utilisateur - jamais aucun autre champ (uid,
      // email, createdAt, profileCompleted, profile, displayName,
      // photoURL...). La condition `diff(...).affectedKeys().hasOnly([...])`
      // exige que l'ENSEMBLE des champs reellement modifies par l'ecriture
      // soit un sous-ensemble de ['role', 'status'] : toute tentative de
      // modifier un champ de profil en meme temps (meme un seul, meme en
      // accompagnement d'un changement de role legitime) fait echouer
      // toute la regle, pas seulement le champ en trop.
      //
      // Les valeurs ecrites sont egalement validees explicitement : seuls
      // 'user'/'admin' sont acceptes pour `role`, et 'pending'/'active'/
      // 'suspended' pour `status`. Les roles futurs (EDITOR, TEACHER,
      // SUPER_ADMIN - deja presents dans les constantes cote application,
      // voir authorization-service.js) ne sont PAS encore autorises ici :
      // tant qu'ils ne sont pas officiellement implementes (aucun ecran ne
      // permet de les attribuer), Firestore les refuse explicitement.
      //
      // Le cas "un administrateur modifie SON PROPRE role/statut" reste
      // explicitement exclu ici (request.auth.uid != userId) : meme un
      // administrateur doit passer par la regle "PROPRIETAIRE" ci-dessus
      // pour son propre document, qui protege deja strictement role/status
      // - un administrateur ne peut donc jamais changer son propre role ou
      // son propre statut, ni via l'interface (voir js/services/admin-
      // service.js, correctif v1.9.1), ni en contournant l'interface.
      allow update: if request.auth != null
                    && isRequesterAdmin()
                    && request.auth.uid != userId
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['role', 'status'])
                    && request.resource.data.role in ['user', 'admin']
                    && request.resource.data.status in ['pending', 'active', 'suspended'];

      // --- Suppression (Sprint 3, inchangee) ---
      allow delete: if false;

      // --- Evaluations (Sprint 4, inchangees) ---
      match /evaluations/{evaluationId} {
        allow read: if request.auth != null && request.auth.uid == userId;

        allow create: if request.auth != null
                      && request.auth.uid == userId
                      && request.resource.data.userId == userId
                      && request.resource.data.id == evaluationId;

        allow update: if request.auth != null
                      && request.auth.uid == userId
                      && request.resource.data.id == resource.data.id
                      && request.resource.data.userId == resource.data.userId
                      && request.resource.data.createdAt == resource.data.createdAt
                      && request.resource.data.completedAt == resource.data.completedAt
                      && request.resource.data.score == resource.data.score
                      && request.resource.data.questions == resource.data.questions
                      && request.resource.data.selection == resource.data.selection;

        allow delete: if false;

        // Piste pour un futur acces administrateur en lecture aux
        // evaluations d'un utilisateur (ex. support, statistiques
        // agregees globales) - NON activee ici, meme logique que ci-dessus :
        // allow read: if request.auth != null && (request.auth.uid == userId || isRequesterAdmin());
      }
    }

    // --- NOUVEAU (Sprint 8) : journal d'audit des actions administrateur ---
    match /audit_logs/{logId} {
      // Lecture reservee aux administrateurs (le journal peut contenir des
      // informations sur n'importe quel utilisateur - jamais accessible a
      // un utilisateur standard, meme sur ses propres entrees).
      allow read: if isRequesterAdmin();

      // Creation reservee aux administrateurs, et uniquement en s'auto-
      // identifiant correctement comme auteur de l'action (empeche un
      // administrateur d'usurper l'identite d'un autre administrateur dans
      // le journal).
      allow create: if isRequesterAdmin()
                    && request.resource.data.adminUid == request.auth.uid;

      // Le journal d'audit est immuable une fois ecrit : ni modification,
      // ni suppression, pour quiconque, y compris un administrateur. C'est
      // une garantie d'integrite du journal, pas seulement une regle
      // d'acces.
      allow update: if false;
      allow delete: if false;
    }

    // =========================================================================
    // catalogue global de questions (Sprint 10 : import JSON ; Sprint 11 : Banque de questions)
    // =========================================================================
    // Collection GLOBALE, jamais sous users/{uid} - les questions sont
    // communes a tous les utilisateurs (voir RAPPORT_SPRINT10.md,
    // "Architecture"). L'IDENTIFIANT DE DOCUMENT est directement
    // l'identifiant pedagogique (ex. "PHARM-BAP-000124"), jamais un
    // identifiant Firestore genere aleatoirement.
    //
    // Acces reserve aux administrateurs pour l'instant (aucune interface ne
    // consomme encore ce catalogue publiquement - "ne pas developper la
    // publication" restait un non-objectif explicite du Sprint 10 ; le
    // Sprint 11 ajoute la NAVIGATION/GESTION administrative de ce
    // catalogue, toujours reservee aux administrateurs, jamais une
    // consultation publique). A ELARGIR le jour ou un futur role EDITOR
    // sera reellement attribuable (ajouter une fonction
    // isRequesterEditorOrAdmin() equivalente a isRequesterAdmin()
    // ci-dessus), et le jour ou la lecture publique des questions PUBLIEES
    // sera necessaire pour alimenter le moteur de quiz depuis Firestore
    // (toujours hors perimetre).
    match /questions/{pedagogicalId} {
      allow read: if isRequesterAdmin();

      // Creation (Sprint 10, inchangee) : l'identifiant du document DOIT
      // correspondre exactement au pedagogicalId contenu dans le document
      // lui-meme ; le statut ecrit doit toujours etre "draft".
      allow create: if isRequesterAdmin()
                    && request.resource.data.pedagogicalId == pedagogicalId
                    && request.resource.data.status == 'draft';

      // --- Mise a jour n°1 (Sprint 10, INCHANGEE) : reecriture complete
      // par l'IMPORTEUR ---
      // Un reimport (js/services/question-parser.js) reconstruit
      // l'integralite du document (contenu, metadonnees, version) et force
      // TOUJOURS le statut a "draft", quel que soit le statut precedent -
      // regle de securite non negociable du Sprint 10, non modifiee ici.
      allow update: if isRequesterAdmin()
                    && request.resource.data.pedagogicalId == resource.data.pedagogicalId
                    && request.resource.data.status == 'draft';

      // --- Mise a jour n°2 (Sprint 11) : transition de statut depuis la
      // Banque de questions (draft/review/published/archived UNIQUEMENT -
      // CORRECTIF : "trash" est retiree de cette liste generale et geree
      // par une regle dediee ci-dessous, plus contrainte) ---
      // Publier / Archiver / Remettre en brouillon (voir js/services/
      // question-bank-service.js) ne modifient JAMAIS que le champ
      // `status` (et `updatedAt`) - jamais le contenu, jamais les
      // metadonnees. `hasOnly` garantit qu'aucun autre champ ne peut etre
      // modifie "au passage" d'un changement de statut.
      //
      // CORRECTIF CRITIQUE (detecte par les tests avant publication) :
      // cette regle verifiait uniquement le NOUVEAU statut demande, jamais
      // l'ANCIEN - une question DEJA A LA CORBEILLE aurait donc pu sauter
      // directement vers "published" (ou tout autre statut de la liste),
      // contournant entierement l'obligation de repasser par "archived"
      // (restauration) avant toute autre transition. La condition
      // `resource.data.status != 'trash'` ci-dessous ferme cette bascule :
      // une question a la corbeille ne peut JAMAIS emprunter cette regle
      // generale, uniquement la regle dediee n°2b ci-dessous (qui ne
      // permet que le retour vers "archived").
      allow update: if isRequesterAdmin()
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt'])
                    && request.resource.data.pedagogicalId == resource.data.pedagogicalId
                    && resource.data.status != 'trash'
                    && request.resource.data.status in ['draft', 'review', 'published', 'archived'];

      // --- Mise a jour n°2b (CORRECTIF, suppression securisee) :
      // transition Archivee <-> Corbeille UNIQUEMENT ---
      // Workflow impose : Question -> Archivee -> Corbeille -> Suppression
      // definitive. Cette regle n'autorise QUE les deux sens de cette
      // transition precise (archived -> trash pour la mise a la corbeille,
      // trash -> archived pour la restauration) - jamais un saut direct
      // depuis draft/review/published vers "trash", ni l'inverse.
      allow update: if isRequesterAdmin()
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt'])
                    && request.resource.data.pedagogicalId == resource.data.pedagogicalId
                    && ((resource.data.status == 'archived' && request.resource.data.status == 'trash')
                        || (resource.data.status == 'trash' && request.resource.data.status == 'archived'));

      // --- Mise a jour n°3 (Sprint 11) : edition limitee ---
      // "Aucune edition complete" (Sprint 11) : seuls explanation/tags/
      // source (+ updatedAt) peuvent etre modifies par cette voie, et le
      // STATUT DOIT RESTER INCHANGE - une simple correction de source ou
      // de tags ne doit jamais republier ou depublier une question par
      // effet de bord.
      allow update: if isRequesterAdmin()
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['explanation', 'tags', 'source', 'updatedAt'])
                    && request.resource.data.pedagogicalId == resource.data.pedagogicalId
                    && request.resource.data.status == resource.data.status;

      // --- Suppression (CORRECTIF, suppression securisee) ---
      // Le Sprint 10 interdisait toute suppression ("allow delete: if
      // false"). Le Sprint 11 l'avait ensuite ouverte a tout administrateur
      // depuis n'importe quel statut - CE CORRECTIF LA RESSERRE : la
      // suppression definitive n'est desormais possible QUE si la question
      // est DEJA a la corbeille (dernier maillon du workflow Question ->
      // Archivee -> Corbeille -> Suppression definitive), jamais en
      // contournant les etapes precedentes. Defense en profondeur : cette
      // contrainte s'applique meme si l'application cliente (js/services/
      // question-bank-service.js, permanentlyDeleteQuestion()) etait
      // elle-meme contournee.
      allow delete: if isRequesterAdmin() && resource.data.status == 'trash';
    }

    // =========================================================================
    // NOUVEAU (Sprint 11) : journal des actions sur les questions
    // =========================================================================
    // Distinct de audit_logs/ (Sprint 8, actions utilisateurs) et de
    // importLogs/ (Sprint 10, operations d'import completes) : trace ICI
    // chaque action individuelle sur UNE question (changement de statut,
    // modification de champ, suppression) depuis la Banque de questions.
    // Meme logique d'immuabilite que les autres journaux.
    match /question_audit_logs/{logId} {
      allow read: if isRequesterAdmin();

      allow create: if isRequesterAdmin()
                    && request.resource.data.adminUid == request.auth.uid;

      allow update: if false;
      allow delete: if false;
    }

    // =========================================================================
    // NOUVEAU (Sprint 12) : Parcours (fondations)
    // =========================================================================
    // Collection GLOBALE, jamais sous users/{uid} - un parcours est commun a
    // tous les utilisateurs, meme principe que questions/ (Sprint 10).
    // L'IDENTIFIANT DE DOCUMENT est directement l'identifiant stable du
    // parcours (ex. "PARC-a1b2c3d4", voir js/services/parcours-metadata-
    // service.js), genere a la creation - jamais un identifiant Firestore
    // aleatoire.
    //
    // "Workflow identique aux questions" (demande explicite du Sprint 12) :
    // memes 3 regles de mise a jour (creation/edition complete, transition
    // de statut generale hors corbeille, transition dediee archived<->trash),
    // meme suppression contrainte au statut "trash" uniquement. Reprend
    // fidelement la structure de questions/ ci-dessus, appliquee a ce
    // nouveau type de contenu.
    //
    // Acces reserve aux administrateurs (aucune interface ne consomme
    // encore ce contenu publiquement - "progression utilisateur" est un
    // non-objectif explicite de ce sprint).
    match /parcours/{parcoursId} {
      allow read: if isRequesterAdmin();

      // Creation : l'identifiant du document DOIT correspondre exactement
      // a l'identifiant contenu dans le document lui-meme ; le statut ecrit
      // doit toujours etre "draft" (jamais publie automatiquement, meme
      // principe que les questions).
      allow create: if isRequesterAdmin()
                    && request.resource.data.id == parcoursId
                    && request.resource.data.status == 'draft';

      // --- Mise a jour n°1 : edition complete (nom, description, public
      // cible, couleur, icone, competences) ---
      // Contrairement aux questions (reecrites uniquement par l'importeur),
      // un parcours peut etre edite librement par son proprietaire
      // administrateur - MAIS jamais l'identifiant, et jamais le statut
      // "au passage" d'une simple edition (voir regle n°2 pour les
      // transitions de statut, separee et dediee).
      allow update: if isRequesterAdmin()
                    && request.resource.data.id == resource.data.id
                    && request.resource.data.status == resource.data.status;

      // --- Mise a jour n°2 : transition de statut (draft/review/published/
      // archived UNIQUEMENT - "trash" gere par une regle dediee ci-dessous,
      // meme principe que questions/, correctif Sprint 11) ---
      allow update: if isRequesterAdmin()
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt'])
                    && request.resource.data.id == resource.data.id
                    && resource.data.status != 'trash'
                    && request.resource.data.status in ['draft', 'review', 'published', 'archived'];

      // --- Mise a jour n°2b : transition Archive <-> Corbeille UNIQUEMENT ---
      // Memes garanties que questions/ (correctif Sprint 11) : jamais un
      // saut direct depuis/vers "trash" en dehors de ce chemin precis.
      allow update: if isRequesterAdmin()
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt'])
                    && request.resource.data.id == resource.data.id
                    && ((resource.data.status == 'archived' && request.resource.data.status == 'trash')
                        || (resource.data.status == 'trash' && request.resource.data.status == 'archived'));

      // --- Suppression : contrainte au statut "trash" uniquement (workflow
      // identique aux questions) ---
      allow delete: if isRequesterAdmin() && resource.data.status == 'trash';
    }

    // Journal des actions de gestion des parcours - meme logique
    // d'immuabilite que question_audit_logs/ ci-dessus.
    match /parcours_audit_logs/{logId} {
      allow read: if isRequesterAdmin();

      allow create: if isRequesterAdmin()
                    && request.resource.data.adminUid == request.auth.uid;

      allow update: if false;
      allow delete: if false;
    }

    // =========================================================================
    // NOUVEAU (Sprint 10, demande complementaire) : journal des imports
    // =========================================================================
    // Meme logique d'immuabilite que audit_logs/ (Sprint 8) : trace CHAQUE
    // import (date, administrateur, fichier, comptages, duree), jamais
    // modifiable ni supprimable, y compris par un administrateur.
    match /importLogs/{logId} {
      allow read: if isRequesterAdmin();

      allow create: if isRequesterAdmin()
                    && request.resource.data.adminUid == request.auth.uid;

      allow update: if false;
      allow delete: if false;
    }
  }
}
